# MantleAgentKit — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Wallet address to monitor (public address only — NO private key needed)
WALLET_ADDRESS=0xYourWalletAddressHere

# Mantle Testnet RPC (public endpoint — no API key required)
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# How often the agent polls in seconds (default: 300 = 5 minutes)
POLL_INTERVAL=300

# Port for API server
PORT=8000
